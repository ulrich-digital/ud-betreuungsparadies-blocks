{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ud-betreuungsparadies/card-button",
    "title": "Card Button",
    "category": "design",
    "icon": "button",
    "description": "Button für Karten mit automatischer Linktyp-Erkennung.",
    "parent": [
        "ud-betreuungsparadies/card-buttons"
    ],
    "supports": {
        "html": false
    },
    "attributes": {
        "linkMode": {
            "type": "string",
            "default": "page"
        },
        "text": {
            "type": "string",
            "default": ""
        },
        "url": {
            "type": "string",
            "default": ""
        },
        "buttonStyle": {
            "type": "string",
            "default": "filled"
        }
    },
    "editorScript": "file:./editor-script.js"
}