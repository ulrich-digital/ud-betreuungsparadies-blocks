{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ud-betreuungsparadies/info-list",
    "title": "Info Liste",
    "category": "design",
    "icon": "editor-table",
    "description": "Container für kurze Informationszeilen.",
    "attributes": {
        "label": {
            "type": "string",
